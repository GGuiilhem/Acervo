{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Acervo",
  "version": "0.6.10",
  "identifier": "br.com.gguillhem.acervo",
  "build": {
    "frontendDist": "frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Acervo",
        "width": 1100,
        "height": 720,
        "minWidth": 760,
        "minHeight": 540,
        "center": true,
        "decorations": false,
        "backgroundColor": "#111827"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
